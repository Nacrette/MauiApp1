<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    x:Class="MauiApp1.Views.FavoritesPage"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:controls="clr-namespace:MauiApp1.Controls"
    Title="My Favorites">

    <Grid>
        <BoxView Background="{StaticResource CosmicBackgroundBrush}" />
        <controls:StarfieldView />

        <ScrollView Padding="22,16">
            <VerticalStackLayout Spacing="20">
                
                <Label Text="My Favorites" Style="{StaticResource CosmicTitle}" />
                
                <Label Text="Please login to save your favorites" 
                       Style="{StaticResource CosmicSubtitle}"
                       IsVisible="{Binding IsLoggedIn, Converter={StaticResource InverseBoolConverter}}" />
                
                <VerticalStackLayout Spacing="12" IsVisible="{Binding IsLoggedIn}">
                    
                    <Label Text="Favorite Planets" Style="{StaticResource CosmicSubtitle}" FontSize="18"
                           IsVisible="{Binding HasPlanetFavorites}" />
                    
                    <CollectionView ItemsSource="{Binding FavoritePlanets}"
                                   IsVisible="{Binding HasPlanetFavorites}">
                        <CollectionView.ItemsLayout>
                            <LinearItemsLayout Orientation="Vertical" ItemSpacing="10" />
                        </CollectionView.ItemsLayout>
                        <CollectionView.ItemTemplate>
                            <DataTemplate>
                                <Border Style="{StaticResource CosmicCardBorder}" Stroke="{Binding AccentColor}">
                                    <Grid ColumnSpacing="12">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="60" />
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>
                                        <Label Text="{Binding Emoji}" FontSize="32" VerticalOptions="Center" HorizontalOptions="Center" />
                                        <VerticalStackLayout Grid.Column="1" Spacing="2" VerticalOptions="Center">
                                            <Label Text="{Binding Name}" FontSize="16" FontAttributes="Bold" />
                                            <Label Text="{Binding Subtitle}" FontSize="11" TextColor="{StaticResource TextSecondary}" LineBreakMode="TailTruncation" />
                                        </VerticalStackLayout>
                                        <HorizontalStackLayout Grid.Column="2" Spacing="8">
                                            <Button Text="Open" Style="{StaticResource GlowingButton}" Padding="10,6"
                                                    Command="{Binding Source={RelativeSource AncestorType={x:Type ContentPage}}, Path=BindingContext.OpenPlanetCommand}"
                                                    CommandParameter="{Binding .}" />
                                            <Button Text="Remove" BackgroundColor="{StaticResource CosmicSurface}" TextColor="{StaticResource TextPrimary}" CornerRadius="18" Padding="10,6"
                                                    Command="{Binding Source={RelativeSource AncestorType={x:Type ContentPage}}, Path=BindingContext.RemovePlanetFavoriteCommand}"
                                                    CommandParameter="{Binding .}" />
                                        </HorizontalStackLayout>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </CollectionView.ItemTemplate>
                    </CollectionView>
                    
                    <Label Text="No planet favorites yet. Explore the Solar System or Milky Way!" 
                           Style="{StaticResource CosmicSubtitle}"
                           IsVisible="{Binding HasPlanetFavorites, Converter={StaticResource InverseBoolConverter}}" />

                    <BoxView HeightRequest="1" BackgroundColor="{StaticResource OutlineSoft}" Margin="0,8" />

                    <Label Text="Favorite APODs" Style="{StaticResource CosmicSubtitle}" FontSize="18"
                           IsVisible="{Binding HasApodFavorites}" />
                    
                    <CollectionView ItemsSource="{Binding FavoriteApods}"
                                   IsVisible="{Binding HasApodFavorites}">
                        <CollectionView.ItemsLayout>
                            <LinearItemsLayout Orientation="Vertical" ItemSpacing="10" />
                        </CollectionView.ItemsLayout>
                        <CollectionView.ItemTemplate>
                            <DataTemplate>
                                <Border Style="{StaticResource CosmicCardBorder}">
                                    <Grid ColumnSpacing="12">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="80" />
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>
                                        <Frame BackgroundColor="{StaticResource CosmicSurface2}" CornerRadius="8" Padding="4">
                                            <Image Source="{Binding Url}" Aspect="AspectFill" WidthRequest="72" HeightRequest="72" />
                                        </Frame>
                                        <VerticalStackLayout Grid.Column="1" Spacing="2" VerticalOptions="Center">
                                            <Label Text="{Binding Title}" FontSize="14" FontAttributes="Bold" LineBreakMode="TailTruncation" />
                                            <Label Text="{Binding Date}" FontSize="11" TextColor="{StaticResource NeonCyan}" />
                                        </VerticalStackLayout>
                                        <HorizontalStackLayout Grid.Column="2" Spacing="8">
                                            <Button Text="View" Style="{StaticResource GlowingButton}" Padding="10,6"
                                                    Command="{Binding Source={RelativeSource AncestorType={x:Type ContentPage}}, Path=BindingContext.ViewApodCommand}"
                                                    CommandParameter="{Binding .}" />
                                            <Button Text="Remove" BackgroundColor="{StaticResource CosmicSurface}" TextColor="{StaticResource TextPrimary}" CornerRadius="18" Padding="10,6"
                                                    Command="{Binding Source={RelativeSource AncestorType={x:Type ContentPage}}, Path=BindingContext.RemoveApodFavoriteCommand}"
                                                    CommandParameter="{Binding .}" />
                                        </HorizontalStackLayout>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </CollectionView.ItemTemplate>
                    </CollectionView>
                    
                    <Label Text="No APOD favorites yet. Tap the heart icon on Today's APOD to save it!" 
                           Style="{StaticResource CosmicSubtitle}"
                           IsVisible="{Binding HasApodFavorites, Converter={StaticResource InverseBoolConverter}}" />
                    
                </VerticalStackLayout>
            </VerticalStackLayout>
        </ScrollView>
    </Grid>
</ContentPage>
