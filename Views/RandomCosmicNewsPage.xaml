<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    x:Class="MauiApp1.Views.RandomCosmicNewsPage"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:controls="clr-namespace:MauiApp1.Controls"
    Title="Random Cosmic News"
    Shell.NavBarIsVisible="False">

    <Grid>
        <!-- APOD hero -->
        <Image Source="{Binding HeroImage}" Aspect="AspectFill" />

        <!-- Dim overlay for readability -->
        <BoxView Color="#000000" Opacity="0.45" />

        <!-- Stars on top of everything -->
        <controls:StarfieldView Opacity="0.9" />

        <Grid Padding="18,16" RowSpacing="12">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <Grid ColumnSpacing="12">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <Button
                    Text="←"
                    WidthRequest="44"
                    HeightRequest="44"
                    CornerRadius="18"
                    BackgroundColor="{StaticResource CosmicSurface}"
                    TextColor="{StaticResource TextPrimary}"
                    Clicked="OnBackClicked" />

                <VerticalStackLayout Grid.Column="1" Spacing="2">
                    <Label Text="Random Cosmic News" FontSize="18" />
                    <Label Text="{Binding DateText}" TextColor="{StaticResource TextSecondary}" FontSize="12" />
                </VerticalStackLayout>
            </Grid>

            <ScrollView Grid.Row="1">
                <VerticalStackLayout Spacing="12">
                    <Label Text="{Binding Title}" FontSize="26" />

                    <ActivityIndicator IsRunning="{Binding IsBusy}" IsVisible="{Binding IsBusy}" />

                    <Border Style="{StaticResource CosmicCardBorder}">
                        <VerticalStackLayout Spacing="10">
                            <Label Text="Transmission Log" TextColor="{StaticResource NeonCyan}" FontSize="12" />
                            <Label Text="{Binding Explanation}" LineBreakMode="WordWrap" />
                        </VerticalStackLayout>
                    </Border>

                    <Label
                        Text="{Binding ErrorMessage}"
                        TextColor="{StaticResource Danger}"
                        IsVisible="{Binding ErrorMessage, Converter={StaticResource StringNotNullOrEmptyConverter}}" />
                </VerticalStackLayout>
            </ScrollView>

            <Button
                Grid.Row="2"
                Text="Explore Again"
                Style="{StaticResource GlowingButton}"
                Command="{Binding ExploreAgainCommand}" />
        </Grid>
    </Grid>
</ContentPage>

