<?xml version="1.0" encoding="UTF-8" ?>
<Shell
    x:Class="MauiApp1.AppShell"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:views="clr-namespace:MauiApp1.Views"
    Title="Planet Explorer Simulator">

    <TabBar>
        <ShellContent
            Title="Home"
            Route="home"
            ContentTemplate="{DataTemplate views:SolarSystemOverviewPage}" />

        <ShellContent
            Title="Daily Trivia"
            Route="trivia"
            ContentTemplate="{DataTemplate views:DailyTriviaPage}" />

        <ShellContent
            Title="Favorites"
            Route="favorites"
            ContentTemplate="{DataTemplate views:FavoritesPage}" />

        <ShellContent
            Title="Settings"
            Route="settings"
            ContentTemplate="{DataTemplate views:SettingsPage}" />
    </TabBar>

</Shell>
